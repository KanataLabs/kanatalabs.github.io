---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Contact | Kanata Labs LLC">
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Contact</h1>
        <p class="subtitle">Get in Touch</p>
      </div>
    </section>
    
    <section class="contact-content">
      <div class="container">
        <div class="contact-info">
          <h2>Kanata Labs LLC</h2>
          <p class="intro">We are open to discussing potential collaborations and inquiries.</p>
          
          <div class="contact-box">
            <p>Please reach out through professional networks or referral contacts.</p>
            <p class="note">Response time: 2-3 business days</p>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 120px 0 60px;
    background-color: var(--color-off-white);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-xs);
  }

  .subtitle {
    color: var(--color-gray);
    font-size: 1.1rem;
  }

  .contact-content {
    padding: var(--spacing-xl) 0;
  }

  .contact-info {
    max-width: 600px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-info h2 {
    margin-bottom: var(--spacing-sm);
  }

  .intro {
    color: var(--color-gray);
    margin-bottom: var(--spacing-lg);
  }

  .contact-box {
    padding: var(--spacing-lg);
    border: 1px solid var(--color-lighter-gray);
  }

  .contact-box p {
    margin-bottom: var(--spacing-sm);
  }

  .note {
    color: var(--color-light-gray);
    font-size: 0.9rem;
    margin-bottom: 0;
  }
</style>
