---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contact | Kanata Labs LLC"
  description="Get in touch with Kanata Labs LLC about software projects, games, partnerships, or legal notices."
>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Contact</h1>
        <p class="subtitle">Tell us about your project or inquiry</p>
      </div>
    </section>

    <section class="contact-content">
      <div class="container">
        <div class="contact-grid">
          <aside class="contact-info">
            <h2>Other ways to reach us</h2>
            <ul>
              <li><strong>Response time</strong>: 1&ndash;3 business days</li>
              <li>
                <strong>Email (backup)</strong>:
                <span class="obf-email">
                  contact <span aria-hidden="true">[at]</span><span class="sr-only">@</span> kanatalabs.com
                </span>
              </li>
            </ul>
            <p class="privacy-note">
              The form below is the fastest way to reach us. We retain
              the information you provide only as long as needed to
              respond. See our <a href="/privacy">Privacy Policy</a>
              and <a href="/terms">Terms of Use</a> for details.
            </p>
          </aside>

          <form
            class="contact-form"
            action="https://formspree.io/f/xbdqeweb"
            method="POST"
          >
            <div class="form-group">
              <label for="name">
                Name <span class="optional">(optional)</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="How should we address you?"
              />
            </div>

            <div class="form-group">
              <label for="email">
                Email <span class="required">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="your@email.com"
                required
              />
            </div>

            <div class="form-group">
              <label for="reason">
                Reason for contact <span class="required">*</span>
              </label>
              <select id="reason" name="reason" required>
                <option value="" disabled selected>Please select…</option>
                <option value="general">General inquiry</option>
                <option value="software">Software project / engagement</option>
                <option value="game">Game development or operations</option>
                <option value="partnership">Partnership or publishing</option>
                <option value="press">Press / media</option>
                <option value="legal">Legal / compliance notice</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="form-group">
              <label for="company">
                Company <span class="optional">(optional)</span>
              </label>
              <input
                type="text"
                id="company"
                name="company"
                placeholder="Organization, studio, or publisher"
              />
            </div>

            <div class="form-group">
              <label for="subject">
                Subject <span class="required">*</span>
              </label>
              <input
                type="text"
                id="subject"
                name="subject"
                placeholder="Short summary"
                required
              />
            </div>

            <div class="form-group">
              <label for="message">
                Details <span class="required">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="6"
                placeholder="Tell us a bit about what you're looking for, timeline, and any constraints we should know about."
                required
              ></textarea>
              <p class="hint">
                For legal notices, please include the relevant URL,
                a description of the issue, and your contact details.
              </p>
            </div>

            <div class="form-group">
              <label class="checkbox-label">
                <input type="checkbox" name="consent" required />
                <span>
                  I agree that Kanata Labs may use the information
                  I provide to respond to this inquiry.
                  <span class="required">*</span>
                </span>
              </label>
            </div>

            <div class="form-group">
              <div
                class="cf-turnstile"
                data-sitekey="0x4AAAAAADEShf8HjlN_hjl-"
              ></div>
            </div>

            <button type="submit" class="submit-btn">Send message</button>
          </form>
        </div>
      </div>
    </section>
  </main>
  <Footer />
  <script
    is:inline
    src="https://challenges.cloudflare.com/turnstile/v0/api.js"
    async
    defer
  ></script>
</Layout>

<style>
  .page-hero {
    padding: 120px 0 60px;
    background-color: var(--color-off-white);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-xs);
  }

  .subtitle {
    color: var(--color-gray);
    font-size: 1.1rem;
  }

  .contact-content {
    padding: var(--spacing-xl) 0;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: var(--spacing-lg);
    max-width: 1100px;
    margin: 0 auto;
  }

  .contact-info h2 {
    font-size: 1.05rem;
    font-weight: 600;
    margin-bottom: var(--spacing-sm);
    color: var(--color-black);
  }

  .contact-info ul {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--spacing-md);
  }

  .contact-info li {
    color: var(--color-gray);
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .obf-email {
    font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    font-size: 0.9rem;
    color: var(--color-black);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .privacy-note {
    font-size: 0.85rem;
    color: var(--color-light-gray);
    line-height: 1.6;
    margin: 0;
  }

  .privacy-note a {
    color: var(--color-black);
    border-bottom: 1px solid var(--color-lighter-gray);
  }

  .privacy-note a:hover {
    border-bottom-color: var(--color-black);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25em;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4em;
  }

  .form-group label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-black);
  }

  .required {
    color: #c0392b;
  }

  .optional {
    color: var(--color-light-gray);
    font-weight: 400;
    font-size: 0.85rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.7em 0.9em;
    background: var(--color-white);
    border: 1px solid var(--color-lighter-gray);
    border-radius: 6px;
    color: var(--color-black);
    font-family: inherit;
    font-size: 1rem;
    transition: var(--transition);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-black);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .hint {
    font-size: 0.8rem;
    color: var(--color-light-gray);
    margin: 0.25em 0 0;
  }

  .checkbox-label {
    display: flex;
    align-items: flex-start;
    gap: 0.5em;
    font-size: 0.9rem;
    font-weight: 400;
    color: var(--color-gray);
    cursor: pointer;
    line-height: 1.5;
  }

  .checkbox-label input[type='checkbox'] {
    margin-top: 0.2em;
    accent-color: var(--color-black);
  }

  .submit-btn {
    align-self: flex-start;
    padding: 0.875rem 1.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--color-black);
    background-color: var(--color-black);
    color: var(--color-white);
    cursor: pointer;
    transition: var(--transition);
  }

  .submit-btn:hover {
    background-color: transparent;
    color: var(--color-black);
  }

  @media (max-width: 768px) {
    .contact-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }
  }
</style>
