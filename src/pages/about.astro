---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="About | Kanata Labs LLC"
  description="Kanata Labs LLC — a software and games studio. We make our own games and software."
>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <h1>About</h1>
        <p class="subtitle">Who we are and what we do</p>
      </div>
    </section>

    <section class="about-content">
      <div class="container">
        <div class="content-block">
          <h2>Company</h2>
          <p>
            Kanata Labs is a software and games studio. We make our
            own games and the software behind them.
          </p>
          <p>
            The company is organized as Kanata Labs LLC, a limited
            liability company registered in the State of Wyoming, United
            States.
          </p>
          <address class="company-address">
            Kanata Labs LLC<br />
            30 N Gould St Ste R<br />
            Sheridan, WY 82801<br />
            United States
          </address>
        </div>

        <div class="content-block">
          <h2>What we work on</h2>
          <p>
            Browser and mobile games, mostly. We build them and keep
            running them after launch — content, monetization,
            analytics, players.
          </p>
          <p>
            The software side is the tooling and products we build
            for ourselves.
          </p>
        </div>

        <div class="content-block">
          <h2>How we work</h2>
          <p>
            Small team. Senior people do the work. We pick a few
            things at a time, not a long queue, and we tend to stay
            with what we ship.
          </p>
        </div>

        <div class="content-block cta-block">
          <h2>Work with us</h2>
          <p>
            If something we're working on sounds interesting, or you
            just want to say hi — get in touch.
          </p>
          <a href="/contact" class="btn">Get in touch</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 120px 0 60px;
    background-color: var(--color-off-white);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-xs);
  }

  .subtitle {
    color: var(--color-gray);
    font-size: 1.1rem;
  }

  .about-content {
    padding: var(--spacing-xl) 0;
  }

  .content-block {
    max-width: 800px;
    margin: 0 auto var(--spacing-lg);
  }

  .content-block:last-child {
    margin-bottom: 0;
  }

  .content-block h2 {
    margin-bottom: var(--spacing-md);
    color: var(--color-black);
  }

  .content-block p {
    margin-bottom: var(--spacing-sm);
    line-height: 1.7;
  }

  .company-address {
    font-style: normal;
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-gray);
    padding: var(--spacing-sm) var(--spacing-md);
    border-left: 2px solid var(--color-lighter-gray);
    margin-top: var(--spacing-sm);
  }

  .cta-block {
    text-align: center;
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-off-white);
  }

  .btn {
    display: inline-block;
    margin-top: var(--spacing-sm);
    padding: 0.875rem 1.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--color-black);
    background-color: var(--color-black);
    color: var(--color-white);
  }

  .btn:hover {
    background-color: transparent;
    color: var(--color-black);
  }
</style>
