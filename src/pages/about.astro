---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="About | Kanata Labs LLC"
  description="Kanata Labs LLC is an independent software and games studio building custom software and developing and operating browser and mobile games."
>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <h1>About</h1>
        <p class="subtitle">Who we are and what we do</p>
      </div>
    </section>

    <section class="about-content">
      <div class="container">
        <div class="content-block">
          <h2>Company</h2>
          <p>
            Kanata Labs is an independent software and games studio. We
            do two things: we build custom software for client companies,
            and we develop and run our own browser and mobile games.
          </p>
          <p>
            The company is organized as Kanata Labs LLC, a limited
            liability company registered in the State of Wyoming, United
            States.
          </p>
        </div>

        <div class="content-block">
          <h2>What we work on</h2>
          <p>
            On the software side, we build web apps, mobile apps,
            backend services, and internal tools for client companies.
          </p>
          <p>
            On the games side, we design and build browser games (HTML5
            / WebGL) and mobile games (iOS and Android). When a game
            goes live we keep running it ourselves — content updates,
            monetization tuning, analytics, and player support.
          </p>
        </div>

        <div class="content-block">
          <h2>How we work</h2>
          <p>
            Small team. The senior people are the ones doing the work.
            We pick a few engagements at a time rather than a queue of
            many, and we tend to stay with what we ship — most of the
            games we launch we are still running ourselves.
          </p>
          <p>
            A typical engagement starts with a short call, then a
            written proposal. One-off builds and ongoing work both fit;
            we will say which fits better when we scope it.
          </p>
        </div>

        <div class="content-block cta-block">
          <h2>Work with us</h2>
          <p>
            If you have a software project, a game in mind, or a live
            title you want help running, we are happy to talk.
          </p>
          <a href="/contact" class="btn">Get in touch</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 120px 0 60px;
    background-color: var(--color-off-white);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-xs);
  }

  .subtitle {
    color: var(--color-gray);
    font-size: 1.1rem;
  }

  .about-content {
    padding: var(--spacing-xl) 0;
  }

  .content-block {
    max-width: 800px;
    margin: 0 auto var(--spacing-lg);
  }

  .content-block:last-child {
    margin-bottom: 0;
  }

  .content-block h2 {
    margin-bottom: var(--spacing-md);
    color: var(--color-black);
  }

  .content-block p {
    margin-bottom: var(--spacing-sm);
    line-height: 1.7;
  }

  .cta-block {
    text-align: center;
    padding-top: var(--spacing-md);
    border-top: 1px solid var(--color-off-white);
  }

  .btn {
    display: inline-block;
    margin-top: var(--spacing-sm);
    padding: 0.875rem 1.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border: 2px solid var(--color-black);
    background-color: var(--color-black);
    color: var(--color-white);
  }

  .btn:hover {
    background-color: transparent;
    color: var(--color-black);
  }
</style>
