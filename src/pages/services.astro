---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Game Development',
    description:
      'Browser and mobile games we make and keep running ourselves.',
    points: [
      'HTML5 / WebGL browser games',
      'Mobile games for iOS and Android',
      'Gameplay, art, and systems design',
      'Backend, accounts, and platform / store SDK integration',
    ],
  },
  {
    title: 'Game Operations & Publishing',
    description:
      'Live ops for the games we publish — content, monetization, analytics, players.',
    points: [
      'Content updates and seasonal events',
      'Monetization design and balancing',
      'Analytics, A/B testing, and reporting',
      'Player support and community',
    ],
  },
  {
    title: 'Software Development',
    description:
      'Web and mobile software we build for our own products.',
    points: [
      'Web and full-stack apps',
      'Mobile apps for iOS and Android',
      'Backend services and APIs',
      'Internal tooling and automation',
    ],
  },
];
---

<Layout
  title="Services | Kanata Labs LLC"
  description="Games and software from Kanata Labs — browser and mobile games we make and run ourselves, and the software behind them."
>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Services</h1>
        <p class="subtitle">What we do</p>
      </div>
    </section>

    <section class="services-content">
      <div class="container">
        <p class="services-intro">
          Games and software we build and run ourselves.
        </p>

        <div class="services-grid">
          {services.map(service => (
            <article class="service-card">
              <h3>{service.title}</h3>
              <p class="service-desc">{service.description}</p>
              <ul class="service-points">
                {service.points.map(point => (
                  <li>{point}</li>
                ))}
              </ul>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 120px 0 60px;
    background-color: var(--color-off-white);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-xs);
  }

  .subtitle {
    color: var(--color-gray);
    font-size: 1.1rem;
  }

  .services-content {
    padding: var(--spacing-xl) 0;
  }

  .services-intro {
    max-width: 760px;
    margin: 0 auto var(--spacing-lg);
    text-align: center;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-md);
    max-width: 1100px;
    margin: 0 auto;
  }

  .service-card {
    padding: var(--spacing-md);
    border: 1px solid var(--color-lighter-gray);
    transition: var(--transition);
    background-color: var(--color-white);
  }

  .service-card:hover {
    border-color: var(--color-black);
  }

  .service-card h3 {
    margin-bottom: var(--spacing-sm);
    color: var(--color-black);
  }

  .service-desc {
    margin-bottom: var(--spacing-sm);
    color: var(--color-gray);
    line-height: 1.6;
  }

  .service-points {
    list-style: none;
    padding: 0;
  }

  .service-points li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.4rem;
    color: var(--color-gray);
    font-size: 0.95rem;
  }

  .service-points li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--color-light-gray);
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
