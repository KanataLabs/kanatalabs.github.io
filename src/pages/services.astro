---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Research & Development',
    description: 'Technical research and experimental development work on software and systems.',
  },
  {
    title: 'Technical Consulting',
    description: 'Advice on system architecture, technology selection, and implementation approaches.',
  },
  {
    title: 'Software Development',
    description: 'Building applications, tools, and systems based on project requirements.',
  },
];
---

<Layout title="Services | Kanata Labs LLC">
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <h1>Services</h1>
        <p class="subtitle">What We Work On</p>
      </div>
    </section>
    
    <section class="services-content">
      <div class="container">
        <div class="services-grid">
          {services.map(service => (
            <div class="service-card">
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 120px 0 60px;
    background-color: var(--color-off-white);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-xs);
  }

  .subtitle {
    color: var(--color-gray);
    font-size: 1.1rem;
  }

  .services-content {
    padding: var(--spacing-xl) 0;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-md);
    max-width: 1000px;
    margin: 0 auto;
  }

  .service-card {
    padding: var(--spacing-lg) var(--spacing-md);
    border: 1px solid var(--color-lighter-gray);
    text-align: center;
    transition: var(--transition);
  }

  .service-card:hover {
    border-color: var(--color-black);
  }

  .service-card h3 {
    margin-bottom: var(--spacing-sm);
    color: var(--color-black);
  }

  .service-card p {
    margin-bottom: 0;
    color: var(--color-gray);
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }

    .service-card {
      padding: var(--spacing-md);
    }
  }
</style>
