---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const services = [
  {
    title: 'Game Development',
    description:
      'Browser and mobile games we make ourselves.',
  },
  {
    title: 'Game Operations',
    description:
      'Ongoing work on live games: updates, balance, analytics, players.',
  },
  {
    title: 'Software Development',
    description:
      'Software projects and tools of our own.',
  },
];
---

<Layout
  title="Services | Kanata Labs LLC"
  description="Games and software from Kanata Labs — the areas we spend our time building and running ourselves."
>
  <Header />
  <main>
    <section class="page-hero">
      <div class="container">
        <h1>What we work on</h1>
        <p class="subtitle">A quick overview</p>
      </div>
    </section>

    <section class="services-content">
      <div class="container">
        <p class="services-intro">
          These are the areas we spend our time on and know well.
        </p>

        <div class="services-grid">
          {services.map(service => (
            <article class="service-card">
              <h3>{service.title}</h3>
              <p class="service-desc">{service.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-hero {
    padding: 120px 0 60px;
    background-color: var(--color-off-white);
    text-align: center;
  }

  .page-hero h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-bottom: var(--spacing-xs);
  }

  .subtitle {
    color: var(--color-gray);
    font-size: 1.1rem;
  }

  .services-content {
    padding: var(--spacing-xl) 0;
  }

  .services-intro {
    max-width: 760px;
    margin: 0 auto var(--spacing-lg);
    text-align: center;
    font-size: 1.05rem;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-md);
    max-width: 1100px;
    margin: 0 auto;
  }

  .service-card {
    padding: var(--spacing-md);
    border: 1px solid var(--color-lighter-gray);
    transition: var(--transition);
    background-color: var(--color-white);
  }

  .service-card:hover {
    border-color: var(--color-black);
  }

  .service-card h3 {
    margin-bottom: var(--spacing-sm);
    color: var(--color-black);
  }

  .service-desc {
    margin-bottom: var(--spacing-sm);
    color: var(--color-gray);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
