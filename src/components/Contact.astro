<section id="contact" class="contact">
  <div class="container">
    <h2 class="section-title">Contact</h2>
    <p class="contact-intro">Ready to collaborate? We'd love to hear from you.</p>
    <div class="contact-info">
      <p><strong>Kanata Labs LLC</strong></p>
      <p>Email: <a href="mailto:contact@kanatalabs.com">contact@kanatalabs.com</a></p>
    </div>
  </div>
</section>

<style>
  .contact {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-black);
    color: var(--color-white);
    text-align: center;
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--spacing-lg);
    position: relative;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background-color: var(--color-white);
    margin: var(--spacing-sm) auto 0;
  }

  .contact-intro {
    color: var(--color-light-gray);
    font-size: 1.1rem;
    margin-bottom: var(--spacing-md);
  }

  .contact-info {
    color: var(--color-lighter-gray);
  }

  .contact-info strong {
    color: var(--color-white);
    font-size: 1.25rem;
  }

  .contact-info a {
    color: var(--color-white);
    border-bottom: 1px solid var(--color-gray);
  }

  .contact-info a:hover {
    border-bottom-color: var(--color-white);
  }
</style>