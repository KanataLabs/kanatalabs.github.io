---
// Cookie consent banner using vanilla-cookieconsent v3.
// Wires Google Consent Mode v2: GA4 is loaded with all storage denied
// in the Layout, then granted (or kept denied) based on the user's choice.
---

<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3.1.0/dist/cookieconsent.css"
/>
<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3.1.0/dist/cookieconsent.umd.js"
  defer
></script>

<script is:inline>
  window.addEventListener('DOMContentLoaded', function () {
    if (!window.CookieConsent || typeof CookieConsent.run !== 'function') {
      // Library failed to load (offline, blocked, etc.). Bail quietly —
      // GA4 stays in default-denied state, which is the safe default.
      return;
    }

    function updateGtagConsent() {
      if (typeof window.gtag !== 'function') return;
      var analyticsGranted = CookieConsent.acceptedCategory('analytics');
      window.gtag('consent', 'update', {
        analytics_storage: analyticsGranted ? 'granted' : 'denied',
      });
    }

    CookieConsent.run({
      guiOptions: {
        consentModal: {
          layout: 'bar',
          position: 'bottom center',
          equalWeightButtons: true,
          flipButtons: false,
        },
        preferencesModal: {
          layout: 'box',
          equalWeightButtons: true,
          flipButtons: false,
        },
      },
      categories: {
        necessary: { enabled: true, readOnly: true },
        analytics: {},
      },
      onConsent: updateGtagConsent,
      onChange: updateGtagConsent,
      language: {
        default: 'en',
        translations: {
          en: {
            consentModal: {
              title: 'We use cookies',
              description:
                'This site uses analytics cookies (Google Analytics) to understand how visitors use it. You can accept or reject non-essential cookies. Essential cookies are always on.',
              acceptAllBtn: 'Accept all',
              acceptNecessaryBtn: 'Reject all',
              showPreferencesBtn: 'Manage preferences',
            },
            preferencesModal: {
              title: 'Cookie preferences',
              acceptAllBtn: 'Accept all',
              acceptNecessaryBtn: 'Reject all',
              savePreferencesBtn: 'Save preferences',
              closeIconLabel: 'Close',
              sections: [
                {
                  title: 'Strictly necessary cookies',
                  description:
                    'These are required for the site to function and cannot be disabled.',
                  linkedCategory: 'necessary',
                },
                {
                  title: 'Analytics cookies',
                  description:
                    'These cookies help us understand how visitors use the site so we can improve it. We use Google Analytics 4. All collected data is aggregated.',
                  linkedCategory: 'analytics',
                },
                {
                  title: 'More information',
                  description:
                    'For details on what we collect and how we use it, see our <a href="/privacy">Privacy Policy</a>. You can change your choice at any time using the link in the footer.',
                },
              ],
            },
          },
        },
      },
    });

    // Expose a manual trigger so the footer link can re-open preferences.
    window.openCookiePreferences = function () {
      if (window.CookieConsent && typeof CookieConsent.showPreferences === 'function') {
        CookieConsent.showPreferences();
      }
    };
  });
</script>

<style is:global>
  /* Match the site's monochrome aesthetic. vanilla-cookieconsent
     supports CSS-variable theming on the .cc--style scope. */
  #cc-main {
    --cc-bg: #ffffff;
    --cc-primary-color: #0a0a0a;
    --cc-secondary-color: #2a2a2a;
    --cc-btn-primary-bg: #0a0a0a;
    --cc-btn-primary-color: #ffffff;
    --cc-btn-primary-hover-bg: #2a2a2a;
    --cc-btn-secondary-bg: #f5f5f5;
    --cc-btn-secondary-color: #0a0a0a;
    --cc-btn-secondary-hover-bg: #e5e5e5;
    --cc-toggle-on-bg: #0a0a0a;
    --cc-toggle-off-bg: #999999;
    --cc-separator-border-color: #e5e5e5;
    --cc-cookie-category-block-bg: #fafafa;
    --cc-cookie-category-block-border: #e5e5e5;
    --cc-overlay-bg: rgba(10, 10, 10, 0.5);
    --cc-font-family: 'Inter', -apple-system, BlinkMacSystemFont,
      'Segoe UI', sans-serif;
    --cc-modal-border-radius: 8px;
    --cc-btn-border-radius: 6px;
  }
</style>
