<section id="about" class="about">
  <div class="container">
    <h2 class="section-title">About</h2>
    <div class="about-content">
      <p>
        Kanata Labs is an independent games studio. We design, build,
        and run our own browser and mobile games.
      </p>
      <p>
        Small team. The senior people are the ones doing the work.
      </p>
    </div>
  </div>
</section>

<style>
  .about {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-off-white);
  }

  .section-title {
    text-align: center;
    margin-bottom: var(--spacing-lg);
    position: relative;
  }

  .section-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background-color: var(--color-black);
    margin: var(--spacing-sm) auto 0;
  }

  .about-content {
    max-width: 800px;
    margin: 0 auto;
    text-align: center;
  }

  .about-content p {
    font-size: 1.1rem;
    margin-bottom: var(--spacing-md);
  }
</style>
